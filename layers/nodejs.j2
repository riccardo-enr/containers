# --- nodejs: Node.js runtime (copilot.lua ships a JS language server) -----
# copilot.lua runs `node copilot/js/language-server.js`; Ubuntu's apt nodejs is
# too old/inconsistent across releases, so pull the NodeSource 22.x LTS to match
# the host (v22). The setup script runs `apt-get update` itself.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*
